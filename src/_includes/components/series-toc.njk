{% if series %}
  {# Find series metadata by slug #}
  {% set seriesMeta = null %}
  {% for meta in seriesMetadata %}
    {% if meta.slug == series %}
      {% set seriesMeta = meta %}
    {% endif %}
  {% endfor %}

  {% if seriesMeta %}
    <nav class="series-toc" aria-label="Series navigation">
      <p class="toc-heading">
        All posts in the
        <a href="/series/{{ seriesMeta.slug }}/">{{ seriesMeta.name }}</a>
        series
      </p>
      <ol class="toc-list">
        {% for postUrl in seriesMeta.posts %}
          {% for post in collections.posts %}
            {% if post.url == postUrl %}
              <li>
                {% if post.url == page.url %}
                  <a href="{{ post.url }}" aria-current="page" class="series-current">{{ post.data.title }}</a>
                {% else %}
                  <a href="{{ post.url }}">{{ post.data.title }}</a>
                {% endif %}
              </li>
            {% endif %}
          {% endfor %}
        {% endfor %}
      </ol>
    </nav>
    <hr class="series-toc-divider" aria-hidden="true">
  {% endif %}
{% endif %}
