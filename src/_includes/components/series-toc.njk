{% if series %}
  {% set seriesName = series %}

  {# Find matching series metadata to get the slug for the series index page #}
  {% set seriesMetaMatches = [] %}
  {% for meta in seriesMetadata %}
    {% if meta.name == seriesName %}
      {% set _ = seriesMetaMatches.push(meta) %}
    {% endif %}
  {% endfor %}

  {# Collect all posts from the same series #}
  {% set seriesPosts = [] %}
  {% for post in collections.posts %}
    {% if post.data.series and post.data.series == seriesName %}
      {% set item = {
        title: post.data.title,
        url: post.url,
        order: (post.data['series-order'] or 999999),
        isCurrent: (post.url == page.url)
      } %}
      {% set _ = seriesPosts.push(item) %}
    {% endif %}
  {% endfor %}

  {# Sort by numeric order #}
  {% set seriesPosts = seriesPosts | sort(false, false, 'order') %}

  <nav class="series-toc" aria-label="Series navigation">
    <p class="toc-heading">
      All posts in the
      {% if seriesMetaMatches[0] %}
        <a href="/series/{{ seriesMetaMatches[0].slug }}/">{{ seriesName }}</a>
      {% else %}
        {{ seriesName }}
      {% endif %}
      series
    </p>
    <ol class="toc-list">
      {% for item in seriesPosts %}
        {% if item.isCurrent %}
          <li>
            <a href="{{ item.url }}" aria-current="page" class="series-current">
              {{ item.title }}
            </a>
          </li>
        {% else %}
          <li><a href="{{ item.url }}">{{ item.title }}</a></li>
        {% endif %}
      {% endfor %}
    </ol>
  </nav>
  <hr class="series-toc-divider" aria-hidden="true">
{% endif %}
