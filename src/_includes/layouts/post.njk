{% extends "layouts/base.njk" %}


{% block content %}
<main id="content" class="post content">
  {% if archivedStatus %}
  <div class="archived-banner" role="note">
    <span class="archived-banner-icon" aria-hidden="true">📜</span>
    <div class="archived-banner-body">
      <strong>Historical Archive</strong>
      <p>This is an older version of this article preserved for historical reference.{% if supersededBy %} <a href="{{ supersededBy }}">Read the current version →</a>{% endif %}</p>
    </div>
  </div>
  {% endif %}
  {% if draftStatus %}
  <div class="draft-banner draft-banner-{{ draftStatus }}" role="status">
    <span class="draft-banner-icon" aria-hidden="true">
      {% if draftStatus === "draft" %}
      🟠
      {% elif draftStatus === "review" %}
      🔵
      {% elif draftStatus === "ready" %}
      🟢
      {% endif %}
    </span>
    <span class="draft-banner-text">
      {% if draftStatus === "draft" %}
        DRAFT — Early work in progress
      {% elif draftStatus === "review" %}
        IN REVIEW — Awaiting final review
      {% elif draftStatus === "ready" %}
        READY — Ready to publish
      {% endif %}
    </span>
  </div>
  {% endif %}
  <!-- Reading progress bar -->
  <div id="reading-progress" class="reading-progress" role="progressbar" aria-label="Reading progress" aria-valuemin="0"
    aria-valuemax="100" aria-valuenow="0" hidden>
    <span class="reading-progress__bar" aria-hidden="true"></span>
  </div>
  <article {% if draftStatus or archivedStatus %}data-pagefind-ignore{% else %}data-pagefind-body{% endif %}>
    <header>
      {% include "components/breadcrumbs.njk" %}
      <h1 class="post-header">{{ title }}</h1>

      <div class="post-metadata">
        <div class="post-metadata-primary" >
          <span class="date-published">{{date | readableDate}}</span>
          <ul class="post-topics">
            {% for topic in topics %}
            <li><a class="topic-name" href="/topics/{{ topic | slugify }}/">{{topic}}</a></li>
            {% endfor %}
          </ul>
        </div>
        {%if dateModified %}
        <div class="date-modified">Updated: {{dateModified | readableDate }}</div>
        {% endif %}
      </div>

      {% if not archivedStatus %}
      <img src="./{{featuredImage}}" alt="" aria-hidden="true" class="post-header-featured-image" loading="eager"
        fetchpriority="high" decoding="async">
      {% endif %}
      <div class="post-header-excerpt">{{excerpt}}</div>
    </header>

    <hr class="post-header-divider" />

    {{ content | safe }}

    <hr class="divider">


  </article>

  {% include "components/social-share.njk" %}

  {% if not series %}
    {% set currentPageObj = { url: page.url, data: { topics: topics, series: series, draftStatus: draftStatus, relatedPosts: relatedPosts } } %}
    {% set related = currentPageObj | relatedPosts(collections.posts, site.maxRelatedPosts) %}
    {% if related.length > 0 %}
      <section class="related-posts" aria-label="Related posts">
        <h2 class="related-posts-heading">Related Posts</h2>
        <ul class="related-posts-list">
          {% for relPost in related %}
            <li>{% linkedPostCompact relPost.url %}</li>
          {% endfor %}
        </ul>
      </section>
    {% endif %}
  {% endif %}

  {% if historicalVersions.length > 0 %}
  <aside class="historical-versions">
    <h2>Older version{{ 's' if historicalVersions.length > 1 else '' }} of this article</h2>
    <ul>
    {% for v in historicalVersions %}
      <li><a href="{{ v.url }}">{{ v.label if v.label else "Archived version" }}{% if v.archivedDate %} ({{ v.archivedDate | readableMonthYear }}){% endif %}</a></li>
    {% endfor %}
    </ul>
  </aside>
  {% endif %}

  <div class="post-footer">
    {% include "components/comments.njk" %}
  </div>

  <script src="/scripts/reading-progress.js" defer></script>

</main>
{% endblock %}

{% block sidebar %}
{% include "components/series-toc.njk" %}
{% if series %}<script src="/scripts/series-toc.js" defer></script>{% endif %}

{% set tocHtml = content | toc %}
{% if tocHtml and (tocHtml | trim) %}
<nav class="toc" aria-label="Table of contents">
  <p class="toc-heading">Table of contents</p>
  <div class="toc-list">
    {{ tocHtml
    | stripNav
    | safe }}
  </div>
</nav>
<script src="/scripts/toc-scrollspy.js" defer></script>
{% endif %}
{% endblock %}
{% block scripts %}
<script src="/scripts/code-block.js" defer></script>
{% endblock %}