---
title: "Series"
permalink: /series/
description: "All article series on this blog."
---
{% extends "layouts/page.njk" %}

{% block pageContent %}
<ul class="series-list">
  {% for series in seriesMetadata %}
    <li class="series-list-item">
      <h2 class="series-list-item-title">
        <a href="/series/{{ series.slug }}/">{{ series.name }}</a>
      </h2>
      <p class="series-list-item-description">{{ series.description }}</p>
      <p class="series-list-item-count">
        {{ series.posts | length }} article{% if series.posts | length != 1 %}s{% endif %}
      </p>
    </li>
  {% endfor %}
</ul>
{% endblock %}
