// markdownlint configuration for blog posts
// https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md
{
  "config": {
    // Validate line length with max 120 characters (exclude code blocks and tables)
    "MD013": { "line_length": 120, "code_blocks": false, "tables": false }
  },
  "globs": ["src/posts/**/*.md"]
}
