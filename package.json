{
  "name": "vojtech-ruzicka-blog",
  "version": "2.0.0",
  "description": "Vojtech Ruzicka's Programming Blog",
  "main": "N/A",
  "scripts": {
    "dev": "npx cross-env ELEVENTY_RUN_MODE=serve eleventy --serve",
    "start:no-drafts": "npx cross-env INCLUDE_DRAFTS=none eleventy --serve",
    "clean": "rimraf _site",
    "build": "npm run clean && npx cross-env INCLUDE_DRAFTS=none eleventy",
    "build:with-drafts": "npm run clean && npx cross-env INCLUDE_DRAFTS=all eleventy",
    "postbuild": "pagefind --site _site",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate": "npm run validate:html && npm run validate:css && npm run validate:js && npm run validate:md  && npm run validate:xml",
    "validate:html": "html-validate \"_site/**/*.html\"",
    "validate:css": "stylelint \"src/styles/**/*.scss\"",
    "validate:js": "eslint .",
    "validate:md": "markdownlint-cli2",
    "validate:xml": "node scripts/validate-xml.mjs",
    "validate:links": "cd _site && linkinator . --retry-errors --config ../linkinator.config.json",
    "validate:links:external": "cd _site && linkinator . --retry-errors --config ../linkinator.config.external.json",
    "format": "npm run format:md && npm run format:css && npm run format:js",
    "format:md": "prettier --write \"**/*.md\"",
    "format:css": "prettier --write \"**/*.scss\"",
    "format:js": "prettier --write \"**/*.js\"",
    "lighthouse": "lhci autorun"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vojtechruz/vojtechruzicka-blog.git"
  },
  "keywords": [
    "blog",
    "programming"
  ],
  "author": "Vojtech Ruzicka",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vojtechruz/vojtechruzicka-blog/issues"
  },
  "homepage": "https://github.com/vojtechruz/vojtechruzicka-blog#readme",
  "type": "module",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@11tyrocks/eleventy-plugin-sass-lightningcss": "^1.3.0",
    "@shikijs/transformers": "^4.0.2",
    "cheerio": "^1.2.0",
    "eleventy-plugin-nesting-toc": "^1.3.0",
    "ffprobe-static": "^3.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@shikijs/markdown-it": "^4.0.2",
    "@xmldom/xmldom": "^0.9.10",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "html-validate": "^10.13.1",
    "jsdom": "^29.0.2",
    "linkinator": "^7.6.1",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdownlint-cli2": "^0.22.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "shiki": "^4.0.2",
    "stylelint": "^17.8.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vitest": "^4.1.4"
  }
}
